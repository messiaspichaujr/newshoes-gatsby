# Domínio base — os subdomínios gatsby. e admin. são criados automaticamente
# gatsby.newshoes.com.br → site Gatsby
# admin.newshoes.com.br  → painel Strapi
DOMAIN=newshoes.com.br

# Email para certificado SSL Let's Encrypt
ACME_EMAIL=contato@newshoes.com.br

# Strapi secrets (gere com: openssl rand -base64 32)
STRAPI_APP_KEYS=key1,key2,key3,key4
STRAPI_API_TOKEN_SALT=strapiTokenSalt123
STRAPI_ADMIN_JWT_SECRET=strapiAdminJwt123
STRAPI_TRANSFER_TOKEN_SALT=strapiTransfer123
STRAPI_JWT_SECRET=strapiJwt123

# Gatsby <-> Strapi API token (criado automaticamente pelo Strapi no primeiro boot)
STRAPI_GATSBY_TOKEN=dev-gatsby-token-change-in-production

# Usuário admin do Strapi (criado automaticamente no primeiro boot)
STRAPI_ADMIN_EMAIL=admin@newshoes.com.br
STRAPI_ADMIN_PASSWORD=Admin1234!
STRAPI_ADMIN_FIRSTNAME=Admin
STRAPI_ADMIN_LASTNAME=NewShoes
